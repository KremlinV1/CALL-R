# GPU-enabled Dockerfile for Face Swap Agent
# Requires NVIDIA GPU + Docker with nvidia-container-toolkit
FROM nvidia/cuda:12.2.2-cudnn8-runtime-ubuntu22.04

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3-pip \
    build-essential \
    libgl1-mesa-glx \
    libglib2.0-0 \
    ffmpeg \
    wget \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Use python3.11 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

# Upgrade pip
RUN python -m pip install --upgrade pip

# Copy and install requirements
COPY face_swap_requirements.txt .
RUN pip install --no-cache-dir -r face_swap_requirements.txt

# Copy application code
COPY face_swap_agent.py .
COPY .env* ./

# Create models directory
RUN mkdir -p /app/models

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV FACE_SWAP_MODEL_PATH=/app/models/inswapper_128.onnx
ENV FACE_SWAP_SOURCE_IMAGE=/app/models/source_face.jpg
ENV FACE_ENHANCER_MODEL_PATH=/app/models/GFPGANv1.4.onnx

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import insightface; import onnxruntime; print('OK')" || exit 1

# Run the face swap agent
CMD ["python", "face_swap_agent.py", "start"]
